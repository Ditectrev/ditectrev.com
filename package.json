    "@types/geojson": "^7946.0.14",
    "@types/jasmine": "^5.1.15",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^6.4.14",
    "@types/three": "^0.179.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "audit-ci": "^7.0.0",
    "browser-sync": "^3.0.4",
    "domino": "^2.1.6",
