{
  "author": "Daniel Danielecki",
  "description": "Web Application for Ditectrev website",
  "email": "contact@ditectrev.com",
  "homepage": "https://gitlab.com/danieldanielecki/ditectrev.com_v3",
  "name": "ditectrev",
  "private": true,
  "url": "https://ditectrev.com",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --poll 2000",
    "build": "ng build",
    "build:production": "ng build --configuration production",
    "build:ssr": "ng build && ng run ditectrev:server",
    "build:ssr:production": "ng build --configuration production && ng run ditectrev:server:production",
    "build-and-deploy:ssr:staging:firebase": "npm run build:ssr && npm run root:starting:index:firebase && firebase deploy",
    "build-and-deploy:ssr:production:firebase": "npm run build:ssr:production && npm run root:starting:index:firebase && firebase deploy",
    "build-and-serve:ssr:staging": "npm run build:ssr && npm run serve:ssr",
    "build-and-serve:ssr:production": "npm run build:ssr:production && npm run serve:ssr",
    "build-and-serve:ssr:staging:firebase": "npm run build:ssr && npm run root:starting:index:firebase && npm run serve:ssr:firebase",
    "build-and-serve:ssr:production:firebase": "npm run build:ssr:production && npm run root:starting:index:firebase && npm run serve:ssr:firebase",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "predeploy": "firebase use --token $FIREBASE_DEPLOY_KEY $CI_ENVIRONMENT_SLUG",
    "deploy": "firebase deploy --token $FIREBASE_DEPLOY_KEY",
    "deploy:cloud_functions": "cd functions && firebase deploy --token $FIREBASE_DEPLOY_KEY",
    "serve:ssr": "node functions/dist/apps/ditectrev-server/main.js",
    "serve:ssr:firebase": "firebase serve",
    "root:starting:index:firebase": "mv functions/dist/apps/ditectrev-server/main.js functions/index.js"
  },
