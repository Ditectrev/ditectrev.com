    "ng-circle-progress": "^1.7.1",
    "ng-recaptcha": "^12.0.0",
    "ng2-charts": "^5.0.4",
    "ngx-mat-intl-tel-input": "^5.0.0",
    "ngx-owl-carousel-o": "^17.0.1",
    "ngx-spinner": "^16.0.2",
    "nodemailer": "^6.9.9",
    "particles.js": "^2.0.0",
