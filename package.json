{
  "author": "Daniel Danielecki",
  "description": "Web Application for Ditectrev website",
  "email": "contact@ditectrev.com",
  "homepage": "https://gitlab.com/danieldanielecki/ditectrev.com_v3",
  "name": "ditectrev",
  "private": true,
  "url": "https://ditectrev.com",
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "prepare:browser-env": "node ./generate-browser-env.mjs",
    "build": "pnpm run prepare:browser-env && ng build",
    "start": "pnpm run prepare:browser-env && ng serve --host 0.0.0.0 --poll 2000",
    "start:e2e": "pnpm run prepare:browser-env && ng serve --host 127.0.0.1 --port 4311 --poll 2000",
    "build:ssr": "pnpm run build && ng run ditectrev:server",
    "build:prerender": "ng run ditectrev:prerender:production",
    "build:ssr:production": "pnpm run prepare:browser-env && ng build --configuration production && ng run ditectrev:server:production",
    "build-and-deploy:ssr:staging:firebase": "npm run build:ssr && npm run root:starting:index:firebase && firebase use \"$CI_ENVIRONMENT_SLUG\" --token \"$FIREBASE_DEPLOY_KEY\" && firebase deploy --force --token \"$FIREBASE_DEPLOY_KEY\"",
    "build-and-deploy:ssr:production:firebase": "npm run build:ssr:production && npm run root:starting:index:firebase && firebase use \"$CI_ENVIRONMENT_SLUG\" --token \"$FIREBASE_DEPLOY_KEY\" && firebase deploy --force --token \"$FIREBASE_DEPLOY_KEY\"",
    "test": "ng test --no-watch",
    "lint": "ng lint",
    "e2e": "start-server-and-test start:e2e http://127.0.0.1:4311 \"playwright test\"",
    "e2e:smoke:deployed": "playwright test e2e/smoke.spec.ts",
    "a11y:axe": "playwright test e2e/a11y-axe.spec.ts",
    "root:starting:index:firebase": "mkdir -p functions/dist && rm -rf functions/dist/ditectrev-browser && cp -R dist/ditectrev-browser functions/dist/ditectrev-browser && mv dist/ditectrev-server/main.js functions/index.js"
  },
  "dependencies": {
    "@angular/animations": "^17.3.0",
    "@angular/cdk": "^17.3.10",
    "@angular/common": "^17.3.0",
    "@angular/compiler": "^17.3.0",
    "@angular/core": "^17.3.0",
    "@angular/fire": "^17.0.1",
    "@angular/forms": "^17.3.0",
    "@angular/material": "^17.3.10",
    "@angular/platform-browser": "^17.3.0",
    "@angular/platform-browser-dynamic": "^17.3.0",
    "@angular/platform-server": "^17.3.0",
    "@angular/router": "^17.3.0",
    "@angular/service-worker": "^17.3.0",
    "@fortawesome/angular-fontawesome": "^0.14.1",
    "@fortawesome/fontawesome-svg-core": "^6.5.1",
    "@fortawesome/free-brands-svg-icons": "^6.5.1",
    "@fortawesome/free-solid-svg-icons": "^6.5.1",
    "angular-google-tag-manager": "^1.11.0",
    "animate.css": "^4.1.1",
    "aos": "^3.0.0-beta.6",
    "chart.js": "^4.4.1",
    "classlist.js": "1.1.20150312",
    "d3": "^7.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "firebase": "^10.8.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^7.2.2",
    "hammerjs": "^2.0.8",
    "helmet": "^8.0.0",
    "intl-tel-input": "^25.15.0",
